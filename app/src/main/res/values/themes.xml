<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AlcoholCalculator" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/cyz_primary</item>
        <item name="colorOnPrimary">@color/cyz_primary_foreground</item>
        <item name="colorPrimaryContainer">@color/cyz_secondary</item>
        <item name="colorOnPrimaryContainer">@color/cyz_secondary_foreground</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/cyz_accent</item>
        <item name="colorOnSecondary">@color/cyz_accent_foreground</item>

        <item name="colorError">@color/cyz_error</item>
        <item name="colorOnError">@color/cyz_error_foreground</item>

        <item name="android:colorBackground">@color/cyz_background</item>
        <item name="colorOnBackground">@color/cyz_foreground</item>
        <item name="colorSurface">@color/cyz_card</item>
        <item name="colorOnSurface">@color/cyz_foreground</item>
        <item name="colorSurfaceVariant">@color/cyz_input_background</item>
        <item name="colorOnSurfaceVariant">@color/cyz_muted_foreground</item>
        <item name="colorOutline">@color/cyz_border</item>

        <!-- Typography -->
        <item name="fontFamily">@font/vazirmatn</item>
        <item name="android:fontFamily">@font/vazirmatn</item>
    </style>
</resources>